{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/((?!api/)(?!assets/).*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|google-inspectiontool|bingbot|yandexbot|baiduspider|facebookexternalhit|twitterbot|whatsapp|telegram|linkedinbot|slackbot|discordbot|applebot|duckduckbot).*"
        }
      ],
      "destination": "/api/render?path=/$1"
    },
    {
      "source": "/((?!api/)(?!assets/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/sitemap",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Vary", "value": "User-Agent" }
      ]
    }
  ]
}
